# LaundryEase Environment Variables
# Copy this file to .env.local and fill in your actual values

# ============================================
# REQUIRED: OAuth (Google Sign-In)
# ============================================
GOOGLE_ID=your_google_oauth_client_id
GOOGLE_SECRET=your_google_oauth_client_secret

# ============================================
# REQUIRED: Database (MongoDB)
# ============================================
MONGODB_URI=mongodb://localhost:27017
# Or for MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DB=laundryease

# ============================================
# REQUIRED: Email (OTP & Notifications)
# ============================================
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_specific_password
# Note: For Gmail, use an App Password, not your regular password

# ============================================
# REQUIRED: SMS (OTP via Twilio)
# ============================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
# Format: +[country code][number] (e.g., +919876543210)

# ============================================
# REQUIRED: Payment Gateway (Razorpay)
# ============================================
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_key_id
# Note: NEXT_PUBLIC_RAZORPAY_KEY_ID is the same as RAZORPAY_KEY_ID but exposed to client

# ============================================
# REQUIRED: RazorpayX (Escrow & Payouts)
# ============================================
RAZORPAYX_ACCOUNT_NUMBER=2323230000000000
# Your RazorpayX account number for holding escrow funds

# ============================================
# REQUIRED: Google Maps API
# ============================================
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# Enable these APIs: Maps JavaScript API, Places API, Geocoding API

# ============================================
# REQUIRED: Cron Security
# ============================================
CRON_SECRET=generate_a_random_secret_string_here
# Generate a strong random string for securing cron endpoints
# Example: openssl rand -base64 32

# ============================================
# REQUIRED: NextAuth (Session & JWT)
# ============================================
NEXTAUTH_SECRET=generate_a_random_secret_string_here
# Generate a strong random string for JWT signing
# Example: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
# Your application URL (optional, defaults to localhost:3000)

# ============================================
# OPTIONAL: Application URLs
# ============================================
# NEXT_PUBLIC_BASE_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# Used for generating links in emails and redirects
# If not set, defaults to NEXTAUTH_URL or http://localhost:3000

# ============================================
# OPTIONAL: Cloudinary (Image Upload)
# ============================================
# CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
# CLOUDINARY_API_KEY=your_cloudinary_api_key
# CLOUDINARY_API_SECRET=your_cloudinary_api_secret
# If not provided, image uploads may use fallback methods

# ============================================
# OPTIONAL: Debug Flags (Development Only)
# ============================================
# OPS_ALERT_EMAIL_TO=ops-team@example.com,backend-oncall@example.com
# OPS_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# OPS_ALERT_WEBHOOK_BEARER=optional_bearer_token_for_webhook
# Alerting channels used by /api/cron/notify-system-alerts
#
# PROVIDER_SEARCH_DEBUG=true
# DEBUG_LOGGING=true
# NODE_ENV=development

# ============================================
# OPTIONAL: Security (Proxy)
# ============================================
# TRUST_PROXY=true
# Set this to "true" only if your app is behind a trusted reverse proxy (like Cloudflare, AWS ALB, Nginx)
# to securely read the x-forwarded-for header for IP Allowlisting.

# ============================================
# OPTIONAL: Rate Limiting (Upstash Redis)
# ============================================
# UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
# UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token
# Required if you want to enable Redis-backed rate limiting for Auth & OTP endpoints
